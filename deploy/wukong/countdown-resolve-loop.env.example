# Wukong Countdown resolve-loop environment template.
#
# Copy to /Users/frank/.voyager/countdown-resolve-loop.env, edit locally,
# and chmod 600. Do not commit the real file. launchd sources it before
# running vyg countdown resolve-loop.

PYTHONUNBUFFERED=1

# Fail closed by default. Set to true only after the SOP dry-run gate passes.
COUNTDOWN_RESOLVE_LOOP_ENABLED=false
COUNTDOWN_MAX_RESOLVES=20

# Required for the fail-closed LLM should-resolve gate. Leave empty in the
# template so preflight fails until the operator supplies the real key locally.
VOYAGER_DEEPSEEK_API_KEY=

# Optional: operator-local allowlist extension. Repos named here are
# authorized for resolution without appearing in the source-tree allowlist;
# they also need a line in the --repos file. Malformed entries fail closed.
# Keep private repo names in this local file only.
#
# This file is SOURCED BY THE SHELL (launchd plist): use the comma-separated
# form for multiple repos — an unquoted space would be parsed as
# "assignment followed by a command" and break the job. If you prefer
# whitespace separators, the value must be quoted:
#   VOYAGER_RESOLVE_EXTRA_REPOS=owner/a,owner/b        # safe unquoted
#   VOYAGER_RESOLVE_EXTRA_REPOS="owner/a owner/b"      # quoted whitespace
VOYAGER_RESOLVE_EXTRA_REPOS=

# Required out-of-band credential check:
#   gh auth token --hostname github.com --user iterwheel-countdown-bot
# The token itself must stay in the gh credential store, never in this file.
